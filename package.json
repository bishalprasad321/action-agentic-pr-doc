{
  "name": "action-agentic-pr-doc",
  "version": "1.0.0",
  "description": "Generate a pull request description using AI based on the changes made in the PR.",
  "author": "Bishal Prasad",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "github-action",
    "pull-request",
    "ai",
    "gpt",
    "pr-description"
  ],
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@octokit/rest": "^20.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
